---
layout: default
---

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="grid md:grid-cols-2 gap-8">
    <div class="text-center md:text-left">
      {%% if resource.data.image.present? %%}
        <img src="{{ resource.data.image }}" alt="{{ resource.data.name }}" class="rounded-lg shadow-lg w-64 h-64 object-cover mx-auto md:mx-0">
      {%% end %%}
    </div>
    
    <div>
      <h1 class="text-4xl font-bold mb-2">{{ resource.data.name }}</h1>
      <p class="text-xl text-gray-600 mb-4">{{ resource.data.affiliation }}</p>
      
      <div class="mb-6">
        <p class="text-lg">{{ resource.data.profile }}</p>
      </div>

      {%% if resource.data.certifications.present? %%}
        <div class="mb-4">
          <h2 class="text-xl font-semibold mb-2">Certifications</h2>
          <ul class="list-disc list-inside">
            {%% for cert in resource.data.certifications %%}
              <li>{{ cert }}</li>
            {%% end %%}
          </ul>
        </div>
      {%% end %%}

      {%% if resource.data.specialties.present? %%}
        <div class="mb-4">
          <h2 class="text-xl font-semibold mb-2">Specialties</h2>
          <ul class="list-disc list-inside">
            {%% for specialty in resource.data.specialties %%}
              <li>{{ specialty }}</li>
            {%% end %%}
          </ul>
        </div>
      {%% end %%}

      {%% if resource.data.languages.present? %%}
        <div class="mb-4">
          <h2 class="text-xl font-semibold mb-2">Languages</h2>
          <ul class="list-disc list-inside">
            {%% for lang in resource.data.languages %%}
              <li>{{ lang }}</li>
            {%% end %%}
          </ul>
        </div>
      {%% end %%}

      {%% if resource.data.social.present? %%}
        <div class="mt-8">
          <h2 class="text-xl font-semibold mb-2">Connect</h2>
          <div class="flex gap-4">
            {%% if resource.data.social.instagram.present? %%}
              <a href="https://instagram.com/{{ resource.data.social.instagram }}" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800">
                Instagram
              </a>
            {%% end %%}
            {%% if resource.data.social.facebook.present? %%}
              <a href="https://facebook.com/{{ resource.data.social.facebook }}" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800">
                Facebook
              </a>
            {%% end %%}
            {%% if resource.data.social.linkedin.present? %%}
              <a href="https://linkedin.com/in/{{ resource.data.social.linkedin }}" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800">
                LinkedIn
              </a>
            {%% end %%}
          </div>
        </div>
      {%% end %%}
    </div>
  </div>

  {%% if resource.content.present? %%}
    <div class="mt-12 prose max-w-none">
      {{ resource.content }}
    </div>
  {%% end %%}
</div> 